# Токен бота від @BotFather
BOT_TOKEN=123456:ABC...

# РЕКОМЕНДОВАНО: ключ OpenRouter (платний, через кредити): https://openrouter.ai/keys
# За наявності має пріоритет — стабільніше за безкоштовний тариф AI Studio.
OPENROUTER_API_KEY=sk-or-...
# Модель на OpenRouter (без суфікса :free — платний варіант без жорстких лімітів)
# OPENROUTER_MODEL=google/gemini-3.5-flash

# Запасний варіант: ключ Gemini API напряму (безкоштовно, ~10 запитів/хв):
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...

# Кому дозволено користуватись ботом: Telegram user id через кому.
# Свій id можна дізнатись у бота @userinfobot.
# Порожнє значення = бот НІКОГО не пускає (fail-closed).
# Явне значення * = відкритий доступ для всіх (тільки для локальних тестів!)
ALLOWED_USER_IDS=

# Необов'язково: модель Gemini (за замовчуванням gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
